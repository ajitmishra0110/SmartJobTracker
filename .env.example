# Copy this file to .env in the same folder, then edit your values.
# Loaded automatically by Spring Boot services and start-all.ps1.
# React UI uses job-tracker-ui/.env for REACT_APP_* variables.

OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gemini-3.5-flash
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_TIMEOUT_SECONDS=30
OPENAI_RESPONSE_FORMAT_ENABLED=true
JWT_SECRET=mysecretkeymysecretkeymysecretkey123
DB_USERNAME=postgres
DB_PASSWORD=postgres
REACT_APP_API_URL=http://localhost:8080
